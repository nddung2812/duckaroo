# ============================================================================
# duckaroo — environment variables
#
# HOW TO USE:
#   1. Copy this file to .env.local:   cp .env.example .env.local
#   2. Fill in your own values below (replace every <PLACEHOLDER>).
#   3. .env.local is gitignored and never committed.
#
# These are the variables the app actually reads (found via process.env.*).
# Leave a variable blank/omit it only if you are not using that feature.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (Postgres — e.g. Neon / Vercel Postgres)
# The app reads DATABASE_URL. The other POSTGRES_*/PG* vars are auto-created
# by the Vercel<>Neon integration; include them if you provision that way,
# otherwise DATABASE_URL alone is enough.
# ---------------------------------------------------------------------------
DATABASE_URL=<postgres-connection-string>
DATABASE_URL_UNPOOLED=<postgres-direct-connection-string>

POSTGRES_URL=<postgres-pooled-url>
POSTGRES_URL_NON_POOLING=<postgres-direct-url>
POSTGRES_PRISMA_URL=<postgres-prisma-url>
POSTGRES_URL_NO_SSL=<postgres-url-no-ssl>
POSTGRES_USER=<db-user>
POSTGRES_HOST=<db-host>
POSTGRES_PASSWORD=<db-password>
POSTGRES_DATABASE=<db-name>
PGHOST=<db-host>
PGHOST_UNPOOLED=<db-host-direct>
PGUSER=<db-user>
PGPASSWORD=<db-password>
PGDATABASE=<db-name>

# ---------------------------------------------------------------------------
# Stripe (payments) — get these from https://dashboard.stripe.com/apikeys
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_SECRET_KEY=sk_live_or_test_xxx
# From the webhook endpoint you create in the Stripe dashboard (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------------------------------------------------------------------------
# Cloudinary (image hosting) — https://console.cloudinary.com
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# ---------------------------------------------------------------------------
# Vercel Blob (file storage) — token from the Blob store in Vercel dashboard
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ---------------------------------------------------------------------------
# Admin dashboard auth
# ---------------------------------------------------------------------------
DASHBOARD_USERNAME=<admin-username>
DASHBOARD_SECRET=<a-long-random-secret>
# Bearer token protecting the service-requests admin API
SERVICE_REQUESTS_ADMIN_TOKEN=<a-long-random-token>

# ---------------------------------------------------------------------------
# Site / deploy
# ---------------------------------------------------------------------------
# Public base URL of the site (used for absolute links, redirects, etc.)
NEXT_PUBLIC_BASE_URL=https://duckaroo.com.au
# Optional: Vercel deploy hook URL, if the app triggers rebuilds
VERCEL_DEPLOY_HOOK_URL=

# ---------------------------------------------------------------------------
# EmailJS (order/enquiry emails)  —  NOTE: currently NOT env-driven.
# The service ID, template ID and public key are hardcoded in the source
# (e.g. app/products/checkout/page.js, app/api/webhook/stripe/route.js).
# To use your own EmailJS account, either edit those files directly or ask
# me to refactor them to read from the vars below:
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxx
